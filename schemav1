openapi: 3.1.0
info:
  title: SST & Governança Canopus API
  description: |
    API corporativa para gestão de Segurança do Trabalho e Governança Documental do Grupo Canopus.
    
    Esta API implementa o princípio absoluto de ZERO INVENÇÃO, garantindo que todos os dados
    sejam extraídos literalmente dos documentos internos oficiais. Suporta investigação de acidentes,
    checklists, relatórios mensais, PGR e procedimentos de segurança.
    
    **Autenticação:** JWT Bearer Token obrigatório em todos os endpoints.
    **Auditoria:** Todos os registros incluem createdAt, updatedAt e createdBy para rastreabilidade.
  version: 2.0.0
  contact:
    name: Grupo Canopus - Departamento de SST
    email: sst@canopus.com.br
  license:
    name: Proprietary
    url: https://canopus.com.br

servers:
  - url: https://api.canopus.com.br/v1
    description: Servidor de Produção
  - url: https://staging-api.canopus.com.br/v1
    description: Servidor de Staging

tags:
  - name: Acidentes
    description: Gestão de investigação e análise de acidentes de trabalho
  - name: Checklists
    description: Checklists de máquinas, equipamentos e procedimentos
  - name: Relatórios
    description: Relatórios mensais de segurança e avaliações
  - name: PGR
    description: Programa de Gestão de Riscos
  - name: Saúde
    description: Endpoints de status e health check

paths:
  /health:
    get:
      operationId: getHealth
      tags:
        - Saúde
      summary: Verifica se a API está online
      responses:
        '200':
          description: API funcionando
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/HealthStatus'

  /acidentes:
    get:
      operationId: listarAcidentes
      tags:
        - Acidentes
      summary: Lista todos os acidentes registrados
      security:
        - bearerAuth: []
      parameters:
        - name: classificacao
          in: query
          schema:
            type: string
            enum:
              - Acidente com lesão com perda de tempo
              - Acidente com lesão sem perda de tempo
              - Acidente de Trajeto
              - Acidente Impessoal
              - Quase Acidente
              - Acidente ambiental
          description: Filtrar por classificação do acidente
        - name: area
          in: query
          schema:
            type: string
          description: Filtrar por área onde ocorreu o acidente
        - name: dataInicio
          in: query
          schema:
            type: string
            format: date
          description: Data de início do período de busca
        - name: dataFim
          in: query
          schema:
            type: string
            format: date
          description: Data de fim do período de busca
        - name: limit
          in: query
          schema:
            type: integer
            default: 20
          description: Número máximo de resultados
        - name: offset
          in: query
          schema:
            type: integer
            default: 0
          description: Número de registros a pular
      responses:
        '200':
          description: Lista de acidentes
          content:
            application/json:
              schema:
                type: object
                properties:
                  data:
                    type: array
                    items:
                      $ref: '#/components/schemas/Acidente'
                  total:
                    type: integer
                  limit:
                    type: integer
                  offset:
                    type: integer
        '401':
          $ref: '#/components/responses/Unauthorized'
        '500':
          $ref: '#/components/responses/InternalServerError'

    post:
      operationId: registrarAcidente
      tags:
        - Acidentes
      summary: Registra um novo acidente
      security:
        - bearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AcidenteInput'
      responses:
        '201':
          description: Acidente registrado com sucesso
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Acidente'
        '400':
          $ref: '#/components/responses/BadRequest'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '500':
          $ref: '#/components/responses/InternalServerError'

  /acidentes/{id}:
    get:
      operationId: obterAcidente
      tags:
        - Acidentes
      summary: Obtém detalhes de um acidente específico
      security:
        - bearerAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
          description: ID do acidente
      responses:
        '200':
          description: Detalhes do acidente
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Acidente'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '404':
          $ref: '#/components/responses/NotFound'
        '500':
          $ref: '#/components/responses/InternalServerError'

    patch:
      operationId: atualizarAcidente
      tags:
        - Acidentes
      summary: Atualiza um acidente existente
      security:
        - bearerAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
          description: ID do acidente
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AcidenteUpdate'
      responses:
        '200':
          description: Acidente atualizado
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Acidente'
        '400':
          $ref: '#/components/responses/BadRequest'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '404':
          $ref: '#/components/responses/NotFound'
        '500':
          $ref: '#/components/responses/InternalServerError'

    delete:
      operationId: removerAcidente
      tags:
        - Acidentes
      summary: Remove um acidente (soft delete)
      security:
        - bearerAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
          description: ID do acidente
      responses:
        '204':
          description: Acidente removido com sucesso
        '401':
          $ref: '#/components/responses/Unauthorized'
        '404':
          $ref: '#/components/responses/NotFound'
        '500':
          $ref: '#/components/responses/InternalServerError'

  /acidentes/{id}/investigacao:
    post:
      operationId: iniciarInvestigacao
      tags:
        - Acidentes
      summary: Inicia investigação formal de um acidente
      security:
        - bearerAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
          description: ID do acidente
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/InvestigacaoInput'
      responses:
        '200':
          description: Investigação iniciada
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Acidente'
        '400':
          $ref: '#/components/responses/BadRequest'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '404':
          $ref: '#/components/responses/NotFound'
        '500':
          $ref: '#/components/responses/InternalServerError'

  /checklists:
    get:
      operationId: listarChecklists
      tags:
        - Checklists
      summary: Lista todos os checklists
      security:
        - bearerAuth: []
      parameters:
        - name: tipo
          in: query
          schema:
            type: string
            enum:
              - Máquinas e Equipamentos
              - Procedimentos de Segurança
              - Inspeção de Área
          description: Tipo de checklist
        - name: limit
          in: query
          schema:
            type: integer
            default: 20
        - name: offset
          in: query
          schema:
            type: integer
            default: 0
      responses:
        '200':
          description: Lista de checklists
          content:
            application/json:
              schema:
                type: object
                properties:
                  data:
                    type: array
                    items:
                      $ref: '#/components/schemas/Checklist'
                  total:
                    type: integer
        '401':
          $ref: '#/components/responses/Unauthorized'
        '500':
          $ref: '#/components/responses/InternalServerError'

    post:
      operationId: criarChecklist
      tags:
        - Checklists
      summary: Cria um novo checklist
      security:
        - bearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ChecklistInput'
      responses:
        '201':
          description: Checklist criado
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Checklist'
        '400':
          $ref: '#/components/responses/BadRequest'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '500':
          $ref: '#/components/responses/InternalServerError'

  /relatorios-mensais:
    get:
      operationId: listarRelatoriosMensais
      tags:
        - Relatórios
      summary: Lista relatórios mensais de segurança
      security:
        - bearerAuth: []
      parameters:
        - name: mes
          in: query
          schema:
            type: integer
            minimum: 1
            maximum: 12
          description: Mês (1-12)
        - name: ano
          in: query
          schema:
            type: integer
          description: Ano
        - name: limit
          in: query
          schema:
            type: integer
            default: 20
        - name: offset
          in: query
          schema:
            type: integer
            default: 0
      responses:
        '200':
          description: Lista de relatórios
          content:
            application/json:
              schema:
                type: object
                properties:
                  data:
                    type: array
                    items:
                      $ref: '#/components/schemas/RelatorioMensal'
                  total:
                    type: integer
        '401':
          $ref: '#/components/responses/Unauthorized'
        '500':
          $ref: '#/components/responses/InternalServerError'

    post:
      operationId: criarRelatorioMensal
      tags:
        - Relatórios
      summary: Cria um novo relatório mensal
      security:
        - bearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/RelatorioMensalInput'
      responses:
        '201':
          description: Relatório criado
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/RelatorioMensal'
        '400':
          $ref: '#/components/responses/BadRequest'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '500':
          $ref: '#/components/responses/InternalServerError'

  /pgr:
    get:
      operationId: listarPGR
      tags:
        - PGR
      summary: Lista Programas de Gestão de Riscos
      security:
        - bearerAuth: []
      parameters:
        - name: area
          in: query
          schema:
            type: string
          description: Filtrar por área
        - name: limit
          in: query
          schema:
            type: integer
            default: 20
        - name: offset
          in: query
          schema:
            type: integer
            default: 0
      responses:
        '200':
          description: Lista de PGRs
          content:
            application/json:
              schema:
                type: object
                properties:
                  data:
                    type: array
                    items:
                      $ref: '#/components/schemas/PGR'
                  total:
                    type: integer
        '401':
          $ref: '#/components/responses/Unauthorized'
        '500':
          $ref: '#/components/responses/InternalServerError'

    post:
      operationId: criarPGR
      tags:
        - PGR
      summary: Cria um novo PGR
      security:
        - bearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PGRInput'
      responses:
        '201':
          description: PGR criado
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PGR'
        '400':
          $ref: '#/components/responses/BadRequest'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '500':
          $ref: '#/components/responses/InternalServerError'

components:
  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
      description: JWT Bearer Token para autenticação

  schemas:
    HealthStatus:
      type: object
      properties:
        status:
          type: string
          enum: [ok, degraded, down]
        timestamp:
          type: string
          format: date-time
        version:
          type: string

    Acidente:
      type: object
      properties:
        id:
          type: string
          format: uuid
          description: ID único do acidente
        dataOcorrencia:
          type: string
          format: date
          description: Data da ocorrência
        classificacao:
          type: string
          enum:
            - Acidente com lesão com perda de tempo
            - Acidente com lesão sem perda de tempo
            - Acidente de Trajeto
            - Acidente Impessoal
            - Quase Acidente
            - Acidente ambiental
          description: Classificação do acidente conforme documento interno
        area:
          type: string
          description: Área onde ocorreu o acidente
        descricaoOcorrencia:
          type: string
          description: Descrição detalhada e literal da ocorrência
        agenteGerador:
          type: string
          description: Agente gerador do acidente
        equipamentosEnvolvidos:
          type: string
          description: Equipamentos envolvidos no acidente
        causasImediatas:
          type: string
          description: Causas imediatas identificadas
        causasBasicas:
          type: string
          description: Causas básicas/raiz do acidente
        acidentado:
          $ref: '#/components/schemas/Acidentado'
        investigacao:
          $ref: '#/components/schemas/Investigacao'
        createdAt:
          type: string
          format: date-time
          description: Data de criação do registro
        updatedAt:
          type: string
          format: date-time
          description: Data da última atualização
        createdBy:
          type: string
          description: ID do usuário que criou o registro
      required:
        - dataOcorrencia
        - classificacao
        - area
        - descricaoOcorrencia
        - createdAt
        - updatedAt
        - createdBy

    AcidenteInput:
      type: object
      properties:
        dataOcorrencia:
          type: string
          format: date
        classificacao:
          type: string
          enum:
            - Acidente com lesão com perda de tempo
            - Acidente com lesão sem perda de tempo
            - Acidente de Trajeto
            - Acidente Impessoal
            - Quase Acidente
            - Acidente ambiental
        area:
          type: string
        descricaoOcorrencia:
          type: string
        agenteGerador:
          type: string
        equipamentosEnvolvidos:
          type: string
        causasImediatas:
          type: string
        causasBasicas:
          type: string
        acidentado:
          $ref: '#/components/schemas/AcidentadoInput'
      required:
        - dataOcorrencia
        - classificacao
        - area
        - descricaoOcorrencia

    AcidenteUpdate:
      type: object
      properties:
        classificacao:
          type: string
          enum:
            - Acidente com lesão com perda de tempo
            - Acidente com lesão sem perda de tempo
            - Acidente de Trajeto
            - Acidente Impessoal
            - Quase Acidente
            - Acidente ambiental
        area:
          type: string
        descricaoOcorrencia:
          type: string
        agenteGerador:
          type: string
        equipamentosEnvolvidos:
          type: string
        causasImediatas:
          type: string
        causasBasicas:
          type: string

    Acidentado:
      type: object
      properties:
        id:
          type: string
          format: uuid
        nome:
          type: string
        matricula:
          type: string
        departamento:
          type: string
        funcao:
          type: string
        dataAdmissao:
          type: string
          format: date
        lesoes:
          type: array
          items:
            type: string
          description: Descrição das lesões sofridas
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time
      required:
        - nome
        - matricula

    AcidentadoInput:
      type: object
      properties:
        nome:
          type: string
        matricula:
          type: string
        departamento:
          type: string
        funcao:
          type: string
        lesoes:
          type: array
          items:
            type: string
      required:
        - nome
        - matricula

    Investigacao:
      type: object
      properties:
        id:
          type: string
          format: uuid
        dataInicio:
          type: string
          format: date-time
        dataEncerramento:
          type: string
          format: date-time
        investigador:
          type: string
          description: Nome do investigador
        status:
          type: string
          enum:
            - Em andamento
            - Concluída
            - Suspensa
        achados:
          type: string
          description: Achados da investigação
        recomendacoes:
          type: array
          items:
            type: string
          description: Recomendações de ações corretivas
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time

    InvestigacaoInput:
      type: object
      properties:
        investigador:
          type: string
        achados:
          type: string
        recomendacoes:
          type: array
          items:
            type: string
      required:
        - investigador

    Checklist:
      type: object
      properties:
        id:
          type: string
          format: uuid
        tipo:
          type: string
          enum:
            - Máquinas e Equipamentos
            - Procedimentos de Segurança
            - Inspeção de Área
        titulo:
          type: string
        descricao:
          type: string
        itens:
          type: array
          items:
            $ref: '#/components/schemas/ItemChecklist'
        dataCriacao:
          type: string
          format: date
        responsavel:
          type: string
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time
        createdBy:
          type: string
      required:
        - tipo
        - titulo
        - itens

    ChecklistInput:
      type: object
      properties:
        tipo:
          type: string
          enum:
            - Máquinas e Equipamentos
            - Procedimentos de Segurança
            - Inspeção de Área
        titulo:
          type: string
        descricao:
          type: string
        itens:
          type: array
          items:
            $ref: '#/components/schemas/ItemChecklistInput'
        responsavel:
          type: string
      required:
        - tipo
        - titulo
        - itens

    ItemChecklist:
      type: object
      properties:
        id:
          type: string
          format: uuid
        descricao:
          type: string
        conforme:
          type: boolean
        observacoes:
          type: string
        dataVerificacao:
          type: string
          format: date

    ItemChecklistInput:
      type: object
      properties:
        descricao:
          type: string
        conforme:
          type: boolean
        observacoes:
          type: string
      required:
        - descricao
        - conforme

    RelatorioMensal:
      type: object
      properties:
        id:
          type: string
          format: uuid
        mes:
          type: integer
          minimum: 1
          maximum: 12
        ano:
          type: integer
        totalAcidentes:
          type: integer
        acidentesComLesao:
          type: integer
        acidentesSemLesao:
          type: integer
        quaseAcidentes:
          type: integer
        areasAfetadas:
          type: array
          items:
            type: string
        indiceFrequencia:
          type: number
          format: float
          description: Taxa de frequência de acidentes
        indiceSeveridade:
          type: number
          format: float
          description: Taxa de severidade
        observacoes:
          type: string
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time
        createdBy:
          type: string
      required:
        - mes
        - ano
        - totalAcidentes

    RelatorioMensalInput:
      type: object
      properties:
        mes:
          type: integer
          minimum: 1
          maximum: 12
        ano:
          type: integer
        totalAcidentes:
          type: integer
        acidentesComLesao:
          type: integer
        acidentesSemLesao:
          type: integer
        quaseAcidentes:
          type: integer
        areasAfetadas:
          type: array
          items:
            type: string
        indiceFrequencia:
          type: number
          format: float
        indiceSeveridade:
          type: number
          format: float
        observacoes:
          type: string
      required:
        - mes
        - ano
        - totalAcidentes

    PGR:
      type: object
      properties:
        id:
          type: string
          format: uuid
        area:
          type: string
        descricao:
          type: string
        riscos:
          type: array
          items:
            $ref: '#/components/schemas/Risco'
        planosAcao:
          type: array
          items:
            $ref: '#/components/schemas/PlanoAcao'
        dataElaboracao:
          type: string
          format: date
        dataProximaRevisao:
          type: string
          format: date
        responsavel:
          type: string
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time
        createdBy:
          type: string
      required:
        - area
        - riscos

    PGRInput:
      type: object
      properties:
        area:
          type: string
        descricao:
          type: string
        riscos:
          type: array
          items:
            $ref: '#/components/schemas/RiscoInput'
        planosAcao:
          type: array
          items:
            $ref: '#/components/schemas/PlanoAcaoInput'
        responsavel:
          type: string
      required:
        - area
        - riscos

    Risco:
      type: object
      properties:
        id:
          type: string
          format: uuid
        descricao:
          type: string
        nivelRisco:
          type: string
          enum:
            - Baixo
            - Médio
            - Alto
            - Crítico
        populacaoExposta:
          type: string
        medidasExistentes:
          type: string
        medidasPropostas:
          type: string

    RiscoInput:
      type: object
      properties:
        descricao:
          type: string
        nivelRisco:
          type: string
          enum:
            - Baixo
            - Médio
            - Alto
            - Crítico
        populacaoExposta:
          type: string
        medidasExistentes:
          type: string
        medidasPropostas:
          type: string
      required:
        - descricao
        - nivelRisco

    PlanoAcao:
      type: object
      properties:
        id:
          type: string
          format: uuid
        descricao:
          type: string
        responsavel:
          type: string
        dataInicio:
          type: string
          format: date
        dataFim:
          type: string
          format: date
        status:
          type: string
          enum:
            - Planejada
            - Em execução
            - Concluída
            - Atrasada
        prioridade:
          type: string
          enum:
            - Baixa
            - Média
            - Alta
            - Crítica

    PlanoAcaoInput:
      type: object
      properties:
        descricao:
          type: string
        responsavel:
          type: string
        dataInicio:
          type: string
          format: date
        dataFim:
          type: string
          format: date
        prioridade:
          type: string
          enum:
            - Baixa
            - Média
            - Alta
            - Crítica
      required:
        - descricao
        - responsavel

    Error:
      type: object
      properties:
        code:
          type: string
          description: Código de erro único
        message:
          type: string
          description: Mensagem de erro legível
        details:
          type: array
          items:
            type: object
            properties:
              field:
                type: string
              message:
                type: string
          description: Detalhes adicionais do erro
      required:
        - code
        - message

  responses:
    BadRequest:
      description: Requisição inválida
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/Error'
          example:
            code: BAD_REQUEST
            message: Os dados fornecidos são inválidos
            details:
              - field: dataOcorrencia
                message: Data é obrigatória

    Unauthorized:
      description: Não autenticado ou token inválido
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/Error'
          example:
            code: UNAUTHORIZED
            message: Token JWT inválido ou expirado

    NotFound:
      description: Recurso não encontrado
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/Error'
          example:
            code: NOT_FOUND
            message: Acidente não encontrado

    InternalServerError:
      description: Erro interno do servidor
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/Error'
          example:
            code: INTERNAL_SERVER_ERROR
            message: Erro ao processar a requisição
